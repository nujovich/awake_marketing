---
interface Props {
  class?: string;
}
const { class: cls = "" } = Astro.props;
---

<div
  class={`relative aspect-square w-full max-w-md mx-auto select-none pointer-events-none ${cls}`}
  aria-hidden="true"
>
  <div class="absolute inset-0 rounded-full bg-gradient-to-br from-vintage-grape-700 via-space-indigo-800 to-space-indigo-950 shadow-2xl shadow-space-indigo-950/40"></div>

  <div
    class="absolute inset-6 rounded-full border border-bone-100/10 animate-[spin_22s_linear_infinite]"
    style="background: conic-gradient(from 0deg, rgba(189,119,66,0.35), transparent 30%);"
  ></div>

  <div class="absolute inset-12 rounded-full border border-bone-100/15"></div>
  <div class="absolute inset-20 rounded-full border border-bone-100/20"></div>
  <div class="absolute inset-28 rounded-full border border-bone-100/25"></div>

  <div
    class="absolute left-1/2 top-1/2 h-3 w-3 -translate-x-1/2 -translate-y-1/2 rounded-full bg-powder-petal-400 shadow-[0_0_24px_rgba(202,146,104,0.7)]"
  ></div>

  <span
    class="absolute top-[28%] left-[30%] h-2 w-2 rounded-full bg-jungle-teal-300 animate-[fade-in_3s_ease-in-out_infinite]"
  ></span>
  <span
    class="absolute top-[64%] left-[58%] h-1.5 w-1.5 rounded-full bg-bone-100 opacity-80 animate-[fade-in_2.4s_ease-in-out_infinite]"
    style="animation-delay: 1s"
  ></span>
  <span
    class="absolute top-[40%] left-[70%] h-1 w-1 rounded-full bg-powder-petal-200 opacity-90 animate-[fade-in_2.8s_ease-in-out_infinite]"
    style="animation-delay: 0.4s"
  ></span>
</div>
