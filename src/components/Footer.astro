---
import Logo from "./Logo.astro";
import { getLocalizedUrl } from "../i18n/utils";
import { getRelativeLocaleUrl } from "astro:i18n";

interface Props {
  t: Record<string, any>;
  locale: string;
}

const { t, locale } = Astro.props;

const year = new Date().getFullYear();

const navItems = [
  { href: getRelativeLocaleUrl(locale, "/"), label: t.nav.inicio },
  {
    href: getLocalizedUrl(locale, "sobre-nosotros"),
    label: t.nav.sobreNosotros,
  },
  { href: getLocalizedUrl(locale, "servicios"), label: t.nav.servicios },
  { href: getLocalizedUrl(locale, "contacto"), label: t.nav.contacto },
];
---

<footer class="bg-violet text-paper">
  <div class="mx-auto max-w-[1280px] px-6 sm:px-14 pt-20 pb-24">
    <div class="grid gap-16 md:grid-cols-12">
      <div class="md:col-span-5">
        <Logo variant="light" />
        <p class="mt-8 max-w-sm text-sm leading-relaxed text-paper/70">
          {t.brand.tagline}
        </p>
        <div class="mt-10 h-px w-16 bg-coral"></div>
        <p
          class="mt-6 font-display text-[11px] font-semibold uppercase tracking-[0.22em] text-paper/70"
        >
          {t.brand.metodoCore}
        </p>
      </div>

      <div class="md:col-span-3">
        <h3
          class="font-display text-[11px] font-semibold uppercase tracking-[0.22em] text-paper/40"
        >
          {t.nav.navegacion}
        </h3>
        <ul class="mt-6 space-y-3">
          {
            navItems.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-sm text-paper hover:text-coral transition-colors duration-200"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="md:col-span-4">
        <h3
          class="font-display text-[11px] font-semibold uppercase tracking-[0.22em] text-paper/40"
        >
          {t.nav.contactoLabel}
        </h3>
        <ul class="mt-6 space-y-3 text-sm">
          <li>
            <a
              href={`mailto:${t.brand.email}`}
              class="hover:text-coral transition-colors"
            >
              {t.brand.email}
            </a>
          </li>
          <li class="text-paper/70">{t.brand.whatsapp}</li>
          <li class="text-paper/70">{t.brand.city}</li>
        </ul>
      </div>
    </div>

    <div
      class="mt-20 pt-8 border-t border-paper/10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 text-[11px] uppercase tracking-[0.22em] text-paper/40 font-display font-medium"
    >
      <span>© {year} · {t.brand.full}</span>
      <span class="text-coral">{t.brand.footerTagline}</span>
    </div>
  </div>
</footer>
