---
import Logo from "./Logo.astro";
import { brand, nav } from "../data/content";

const year = new Date().getFullYear();
---

<footer class="bg-violet text-paper">
  <div class="mx-auto max-w-[1280px] px-6 sm:px-14 pt-20 pb-24">
    <div class="grid gap-16 md:grid-cols-12">
      <div class="md:col-span-5">
        <Logo variant="light" />
        <p class="mt-8 max-w-sm text-sm leading-relaxed text-paper/70">
          {brand.tagline}
        </p>
        <div class="mt-10 h-px w-16 bg-coral"></div>
        <p
          class="mt-6 font-display text-[11px] font-semibold uppercase tracking-[0.22em] text-paper/70"
        >
          Método CORE
        </p>
      </div>

      <div class="md:col-span-3">
        <h3
          class="font-display text-[11px] font-semibold uppercase tracking-[0.22em] text-paper/40"
        >
          Navegación
        </h3>
        <ul class="mt-6 space-y-3">
          {
            nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-sm text-paper hover:text-coral transition-colors duration-200"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="md:col-span-4">
        <h3
          class="font-display text-[11px] font-semibold uppercase tracking-[0.22em] text-paper/40"
        >
          Contacto
        </h3>
        <ul class="mt-6 space-y-3 text-sm">
          <li>
            <a
              href={`mailto:${brand.email}`}
              class="hover:text-coral transition-colors"
            >
              {brand.email}
            </a>
          </li>
          <li class="text-paper/70">{brand.whatsapp}</li>
          <li class="text-paper/70">{brand.city}</li>
        </ul>
      </div>
    </div>

    <div
      class="mt-20 pt-8 border-t border-paper/10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 text-[11px] uppercase tracking-[0.22em] text-paper/40 font-display font-medium"
    >
      <span>© {year} · {brand.full}</span>
      <span class="text-coral">Sin excusas. Resultados medibles.</span>
    </div>
  </div>
</footer>
