---
import Logo from "./Logo.astro";
import { brand, nav } from "../data/content";

const year = new Date().getFullYear();
---

<footer class="mt-24 bg-space-indigo-950 text-bone-100">
  <div class="mx-auto max-w-6xl px-5 sm:px-8 py-16">
    <div class="grid gap-12 md:grid-cols-3">
      <div>
        <Logo variant="light" />
        <p class="mt-4 max-w-sm text-sm leading-relaxed text-bone-200/80">
          {brand.tagline}
        </p>
      </div>

      <div>
        <h3 class="text-xs uppercase tracking-[0.2em] text-bone-200/50">
          Navegación
        </h3>
        <ul class="mt-4 space-y-2">
          {
            nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-sm text-bone-100 hover:text-powder-petal-300 transition-colors duration-200"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h3 class="text-xs uppercase tracking-[0.2em] text-bone-200/50">
          Contacto
        </h3>
        <ul class="mt-4 space-y-2 text-sm">
          <li>
            <a
              href={`mailto:${brand.email}`}
              class="hover:text-powder-petal-300 transition-colors"
            >
              {brand.email}
            </a>
          </li>
          <li class="text-bone-200/70">{brand.whatsapp}</li>
          <li class="text-bone-200/70">{brand.city}</li>
        </ul>
      </div>
    </div>

    <div
      class="mt-14 pt-6 border-t border-bone-100/10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 text-xs text-bone-200/50"
    >
      <span>© {year} {brand.full}. Todos los derechos reservados.</span>
      <span class="font-display italic text-bone-200/70">
        Visión de Radar · Método CORE
      </span>
    </div>
  </div>
</footer>
