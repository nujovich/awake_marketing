---
interface Props {
  class?: string;
  variant?: "dark" | "light";
}
const { class: cls = "", variant = "dark" } = Astro.props;
const text = variant === "light" ? "text-paper" : "text-ink";
const sub = variant === "light" ? "text-paper/60" : "text-graphite/70";
---

<a href="/" class={`inline-flex flex-col leading-none ${cls}`}>
  <span class={`font-display text-2xl font-extrabold tracking-[-0.02em] ${text}`}>
    AWAKE
  </span>
  <span
    class={`mt-1 font-display text-[9px] font-semibold uppercase tracking-[0.32em] ${sub}`}
  >
    Marketing Digital
  </span>
</a>
