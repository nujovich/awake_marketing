---
interface Props {
  class?: string;
  variant?: "dark" | "light";
}
const { class: cls = "", variant = "dark" } = Astro.props;
const text = variant === "light" ? "text-bone-50" : "text-space-indigo-900";
const accent = variant === "light" ? "text-powder-petal-300" : "text-powder-petal-500";
---

<a href="/" class={`group inline-flex items-center gap-2 ${cls}`}>
  <svg
    aria-hidden="true"
    width="28"
    height="28"
    viewBox="0 0 32 32"
    fill="none"
    class={`${accent} transition-transform duration-300 group-hover:rotate-12`}
  >
    <circle cx="16" cy="16" r="14" stroke="currentColor" stroke-width="1.5" opacity="0.35"></circle>
    <circle cx="16" cy="16" r="9" stroke="currentColor" stroke-width="1.5" opacity="0.6"></circle>
    <circle cx="16" cy="16" r="3.5" fill="currentColor"></circle>
    <path
      d="M16 2 L16 6 M16 26 L16 30 M2 16 L6 16 M26 16 L30 16"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
    ></path>
  </svg>
  <span class={`font-display text-xl font-semibold tracking-tight ${text}`}>
    awake
  </span>
</a>
