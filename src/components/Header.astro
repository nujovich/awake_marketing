---
import Logo from "./Logo.astro";
import Button from "./Button.astro";
import { nav } from "../data/content";

const { pathname } = Astro.url;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
---

<header
  class="sticky top-0 z-40 backdrop-blur-md bg-bone-50/80 border-b border-space-indigo-900/5"
  transition:persist
>
  <div class="mx-auto max-w-6xl px-5 sm:px-8">
    <div class="flex h-16 items-center justify-between">
      <Logo />

      <nav class="hidden md:flex items-center gap-1">
        {
          nav.map((item) => (
            <a
              href={item.href}
              class:list={[
                "rounded-full px-4 py-2 text-sm font-medium transition-colors duration-200",
                isActive(item.href)
                  ? "text-space-indigo-900 bg-space-indigo-900/5"
                  : "text-space-indigo-800/70 hover:text-space-indigo-900 hover:bg-space-indigo-900/5",
              ]}
            >
              {item.label}
            </a>
          ))
        }
      </nav>

      <div class="hidden md:block">
        <Button href="/contacto" variant="primary">Consultoría gratis</Button>
      </div>

      <button
        id="nav-toggle"
        class="md:hidden inline-flex h-10 w-10 items-center justify-center rounded-full text-space-indigo-900 hover:bg-space-indigo-900/5 transition-colors"
        aria-label="Abrir menú"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 12h18"></path>
          <path d="M3 6h18"></path>
          <path d="M3 18h18"></path>
        </svg>
      </button>
    </div>

    <div
      id="mobile-nav"
      class="md:hidden hidden pb-4 pt-1 border-t border-space-indigo-900/5"
    >
      <nav class="flex flex-col gap-1">
        {
          nav.map((item) => (
            <a
              href={item.href}
              class:list={[
                "rounded-lg px-4 py-3 text-sm font-medium transition-colors",
                isActive(item.href)
                  ? "text-space-indigo-900 bg-space-indigo-900/5"
                  : "text-space-indigo-800/70 hover:text-space-indigo-900 hover:bg-space-indigo-900/5",
              ]}
            >
              {item.label}
            </a>
          ))
        }
        <a
          href="/contacto"
          class="mt-2 inline-flex items-center justify-center rounded-full bg-space-indigo-700 px-4 py-3 text-sm font-medium text-bone-50 hover:bg-space-indigo-800 transition-colors"
        >
          Consultoría gratis
        </a>
      </nav>
    </div>
  </div>
</header>

<script>
  const setupNav = () => {
    const toggle = document.getElementById("nav-toggle");
    const menu = document.getElementById("mobile-nav");
    if (!toggle || !menu) return;
    toggle.addEventListener("click", () => {
      const open = menu.classList.toggle("hidden") === false;
      toggle.setAttribute("aria-expanded", String(open));
    });
  };
  setupNav();
  document.addEventListener("astro:page-load", setupNav);
</script>
