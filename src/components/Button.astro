---
type Variant = "primary" | "secondary" | "ghost" | "ink";

interface Props {
  href?: string;
  variant?: Variant;
  type?: "button" | "submit";
  class?: string;
  arrow?: boolean;
}

const {
  href,
  variant = "primary",
  type = "button",
  class: cls = "",
  arrow = true,
} = Astro.props;

const base =
  "group inline-flex items-center justify-center gap-3 px-6 py-3 font-display text-xs font-semibold uppercase tracking-[0.18em] transition-all duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-paper focus-visible:ring-violet";

const styles: Record<Variant, string> = {
  primary:
    "bg-violet text-paper hover:bg-violet-dark",
  secondary:
    "bg-gold text-ink hover:bg-ink hover:text-gold",
  ghost:
    "text-ink hover:text-violet border-b border-ink hover:border-violet pb-1 px-0",
  ink: "bg-ink text-paper hover:bg-gold hover:text-ink",
};

const className = `${base} ${styles[variant]} ${cls}`.trim();

const Tag = href ? "a" : "button";
---

<Tag class={className} href={href} type={!href ? type : undefined}>
  <slot />
  {
    arrow && (
      <svg
        aria-hidden="true"
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="transition-transform duration-200 group-hover:translate-x-1"
      >
        <path d="M5 12h14" />
        <path d="m12 5 7 7-7 7" />
      </svg>
    )
  }
</Tag>
