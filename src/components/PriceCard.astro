---
import Badge from "./Badge.astro";
import type { Tier } from "../data/services";

interface Props {
  tier: Tier;
}
const { tier } = Astro.props;
const featured = !!tier.featured;
---

<article
  class:list={[
    "reveal group relative flex h-full flex-col rounded-3xl p-7 sm:p-8 transition-all duration-300 hover:-translate-y-1",
    featured
      ? "bg-space-indigo-900 text-bone-50 shadow-xl shadow-space-indigo-900/15"
      : "bg-bone-100 text-space-indigo-900 ring-1 ring-space-indigo-900/5 hover:ring-space-indigo-900/15 hover:shadow-lg",
  ]}
>
  {
    tier.badge && (
      <div class="absolute -top-3 left-7">
        <Badge tone={featured ? "petal" : "teal"}>{tier.badge}</Badge>
      </div>
    )
  }

  <header>
    <h3
      class:list={[
        "font-display text-2xl font-semibold leading-tight",
        featured ? "text-bone-50" : "text-space-indigo-900",
      ]}
    >
      {tier.name}
    </h3>
    <p
      class:list={[
        "mt-2 text-sm leading-relaxed",
        featured ? "text-bone-200/80" : "text-space-indigo-800/70",
      ]}
    >
      {tier.tagline}
    </p>
  </header>

  <div class="mt-6 flex items-baseline gap-2">
    <span
      class:list={[
        "font-display text-4xl font-semibold tracking-tight",
        featured ? "text-powder-petal-300" : "text-space-indigo-900",
      ]}
    >
      {tier.price}
    </span>
  </div>
  {
    tier.priceNote && (
      <p
        class:list={[
          "mt-1 text-xs",
          featured ? "text-bone-200/60" : "text-space-indigo-800/60",
        ]}
      >
        {tier.priceNote}
      </p>
    )
  }
  {
    tier.time && (
      <p
        class:list={[
          "mt-3 text-xs uppercase tracking-[0.18em]",
          featured ? "text-jungle-teal-300" : "text-jungle-teal-700",
        ]}
      >
        Tiempo estimado · {tier.time}
      </p>
    )
  }

  <ul class="mt-6 space-y-3 text-sm">
    {
      tier.features.map((feature) => (
        <li class="flex items-start gap-3">
          <svg
            class:list={[
              "mt-0.5 h-4 w-4 flex-none",
              featured ? "text-powder-petal-300" : "text-jungle-teal-600",
            ]}
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.4"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M20 6 9 17l-5-5" />
          </svg>
          <span
            class:list={[
              "leading-relaxed",
              featured ? "text-bone-100/90" : "text-space-indigo-900/85",
            ]}
          >
            {feature}
          </span>
        </li>
      ))
    }
  </ul>

  {
    tier.cta && (
      <a
        href={tier.cta.href}
        class:list={[
          "mt-8 inline-flex items-center justify-center gap-2 rounded-full px-5 py-3 text-sm font-medium transition-all duration-200 hover:-translate-y-0.5",
          featured
            ? "bg-powder-petal-500 text-bone-50 hover:bg-powder-petal-400"
            : "bg-space-indigo-900 text-bone-50 hover:bg-space-indigo-800",
        ]}
      >
        {tier.cta.label}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    )
  }
</article>
