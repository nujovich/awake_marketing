---
import type { Tier } from "../data/services";

interface Props {
  tier: Tier;
}
const { tier } = Astro.props;
const featured = !!tier.featured;
---

<article
  class:list={[
    "reveal group relative flex h-full flex-col p-8 sm:p-10 transition-colors duration-300",
    featured
      ? "bg-violet text-paper"
      : "bg-paper text-ink border border-violet hover:border-violet-deep",
  ]}
>
  {
    tier.badge && (
      <div class="absolute -top-3 left-8">
        <span
          class:list={[
            "inline-block px-3 py-1 font-display text-[10px] font-semibold uppercase tracking-[0.22em]",
            featured ? "bg-coral text-paper" : "bg-ink text-paper",
          ]}
        >
          {tier.badge}
        </span>
      </div>
    )
  }

  <header>
    <h3
      class:list={[
        "font-display text-2xl font-bold tracking-[-0.01em]",
        featured ? "text-paper" : "text-ink",
      ]}
    >
      {tier.name}
    </h3>
    <p
      class:list={[
        "mt-3 text-sm font-light leading-relaxed",
        featured ? "text-paper/80" : "text-graphite/80",
      ]}
    >
      {tier.tagline}
    </p>
  </header>

  <div class:list={["mt-8 h-px w-12", featured ? "bg-coral" : "bg-violet"]}></div>

  <div class="mt-6 flex items-baseline gap-2">
    <span
      class:list={[
        "font-display text-[42px] font-light leading-none tracking-tight",
        featured ? "text-paper" : "text-ink",
      ]}
    >
      {tier.price}
    </span>
  </div>
  {
    tier.priceNote && (
      <p
        class:list={[
          "mt-2 text-xs font-light italic",
          featured ? "text-paper/60" : "text-graphite/60",
        ]}
      >
        {tier.priceNote}
      </p>
    )
  }
  {
    tier.time && (
      <p
        class:list={[
          "mt-4 font-display text-[10px] font-semibold uppercase tracking-[0.22em]",
          featured ? "text-paper/60" : "text-violet",
        ]}
      >
        Tiempo · {tier.time}
      </p>
    )
  }

  <ul class="mt-8 space-y-3 text-sm font-light">
    {
      tier.features.map((feature) => (
        <li class="flex items-start gap-3">
          <span
            class:list={[
              "mt-2 inline-block h-1.5 w-1.5 flex-none",
              featured ? "bg-coral" : "bg-violet",
            ]}
          />
          <span
            class:list={[
              "leading-relaxed",
              featured ? "text-paper/90" : "text-ink/85",
            ]}
          >
            {feature}
          </span>
        </li>
      ))
    }
  </ul>

  {
    tier.cta && (
      <a
        href={tier.cta.href}
        class:list={[
          "mt-10 inline-flex items-center justify-center gap-2 px-6 py-3 font-display text-[11px] font-semibold uppercase tracking-[0.22em] transition-colors",
          featured
            ? "bg-paper text-violet hover:bg-violet-soft"
            : "bg-ink text-paper hover:bg-violet",
        ]}
      >
        {tier.cta.label}
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
        </svg>
      </a>
    )
  }
</article>
