---
import { coreMethodCompact, coreMethodFull } from "../data/content";

interface Props {
  variant?: "compact" | "full";
  tone?: "light" | "dark";
}

const { variant = "compact", tone = "light" } = Astro.props;
const steps = variant === "full" ? coreMethodFull : coreMethodCompact;

const cardBorder =
  tone === "dark" ? "border-paper/15 hover:border-coral" : "border-violet-line hover:border-violet";
const cardBg = tone === "dark" ? "bg-transparent" : "bg-paper";
const letterColor = tone === "dark" ? "text-coral" : "text-violet";
const titleColor = tone === "dark" ? "text-paper" : "text-ink";
const bodyColor = tone === "dark" ? "text-paper/70" : "text-graphite/80";
const summaryColor = tone === "dark" ? "text-paper/40" : "text-violet/60";
const ruleColor = tone === "dark" ? "bg-paper/15" : "bg-violet-line";
---

<ol class="grid gap-0 md:grid-cols-2 lg:grid-cols-4 border-t border-l-0 md:border-l border-r-0 md:border-r border-b
  border-current/0">
  {
    steps.map((step, i) => (
      <li
        class={`reveal group relative flex flex-col p-8 sm:p-10 border-b ${cardBorder} ${cardBg} ${i < steps.length - 1 ? "lg:border-r" : ""} transition-colors duration-300`}
        style={`transition-delay: ${i * 60}ms`}
      >
        <div class="flex items-baseline justify-between">
          <span class={`font-display text-7xl font-extrabold leading-none ${letterColor}`}>
            {step.letter}
          </span>
          <span class={`font-display text-[10px] font-semibold uppercase tracking-[0.22em] ${summaryColor}`}>
            {String(i + 1).padStart(2, "0")}
          </span>
        </div>
        <div class={`mt-6 h-px w-10 ${ruleColor}`}></div>
        <h3 class={`mt-6 font-display text-xl font-bold tracking-[-0.01em] ${titleColor}`}>
          {step.title}
          {"summary" in step && step.summary && (
            <span class={`block mt-1 font-sans text-xs font-light italic ${summaryColor}`}>
              {step.summary}
            </span>
          )}
        </h3>
        <p class={`mt-4 text-sm font-light leading-relaxed ${bodyColor}`}>{step.body}</p>
      </li>
    ))
  }
</ol>
