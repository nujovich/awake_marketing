---
interface Props {
  eyebrow?: string;
  title: string;
  intro?: string;
  align?: "left" | "center";
  tone?: "light" | "dark";
  number?: string;
}

const {
  eyebrow,
  title,
  intro,
  align = "left",
  tone = "light",
  number,
} = Astro.props;

const wrap = align === "center" ? "text-center mx-auto max-w-3xl" : "max-w-3xl";
const eyebrowColor = tone === "dark" ? "text-paper/70" : "text-violet";
const titleColor = tone === "dark" ? "text-paper" : "text-ink";
const introColor = tone === "dark" ? "text-paper/70" : "text-graphite/80";
const numColor = tone === "dark" ? "text-paper/30" : "text-violet/30";
---

<div class={`reveal ${wrap}`}>
  {
    number && (
      <p class={`num ${numColor}`}>
        {number}
      </p>
    )
  }
  {
    eyebrow && (
      <p class={`font-display text-[11px] font-semibold uppercase tracking-[0.22em] ${eyebrowColor} ${number ? "mt-2" : ""}`}>
        — {eyebrow}
      </p>
    )
  }
  <h2
    class={`mt-5 font-display text-3xl sm:text-4xl md:text-[44px] font-bold leading-[1.02] tracking-[-0.02em] ${titleColor}`}
  >
    {title}
  </h2>
  {
    intro && (
      <p class={`mt-6 max-w-2xl ${align === "center" ? "mx-auto" : ""} text-base sm:text-lg font-light leading-relaxed ${introColor}`}>
        {intro}
      </p>
    )
  }
</div>
