---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import SectionTitle from "../components/SectionTitle.astro";
import ValueCard from "../components/ValueCard.astro";
import {
  brand,
  mision,
  vision,
  valores,
  sinceridad,
  glosario,
} from "../data/content";

const icons: Array<"radar" | "flame" | "compass" | "spark" | "diamond"> = [
  "radar",
  "flame",
  "compass",
  "spark",
  "diamond",
];
---

<Layout
  title={`Sobre nosotros — ${brand.full}`}
  description="Quiénes somos, por qué nos llamamos Awake y cómo trabajamos. Misión, visión y valores."
>
  {/* HERO */}
  <section class="relative overflow-hidden bg-bone-50 py-20 sm:py-28">
    <div
      class="absolute inset-0 -z-10 opacity-50"
      style="background: radial-gradient(50% 50% at 70% 30%, rgba(108,91,164,0.18), transparent 60%);"
    >
    </div>
    <div class="mx-auto max-w-4xl px-5 sm:px-8 text-center">
      <p
        class="reveal text-xs font-medium uppercase tracking-[0.22em] text-powder-petal-600"
      >
        Por qué nos llamamos Awake
      </p>
      <h1
        class="reveal mt-5 font-display text-4xl sm:text-5xl md:text-6xl font-semibold leading-[1.05] tracking-tight text-space-indigo-900"
      >
        Despertamos la claridad estratégica para que las marcas dejen de ser
        <span class="italic text-vintage-grape-700">simplemente una opción</span
        >
        y se conviertan en
        <span class="italic text-powder-petal-600">la solución</span>.
      </h1>
    </div>
  </section>

  {/* MISIÓN + VISIÓN */}
  <section class="bg-bone-50 py-20 sm:py-24">
    <div class="mx-auto max-w-6xl px-5 sm:px-8 grid gap-10 md:grid-cols-2">
      <article
        class="reveal rounded-3xl bg-bone-100 p-8 sm:p-10 ring-1 ring-space-indigo-900/5"
      >
        <p class="text-xs uppercase tracking-[0.22em] text-jungle-teal-700">
          Misión
        </p>
        <h2
          class="mt-3 font-display text-2xl sm:text-3xl font-semibold text-space-indigo-900"
        >
          Lo que hacemos todos los días.
        </h2>
        <p class="mt-5 leading-relaxed text-space-indigo-800/80">
          {mision}
        </p>
      </article>

      <article
        class="reveal rounded-3xl bg-space-indigo-900 p-8 sm:p-10 text-bone-50"
      >
        <p class="text-xs uppercase tracking-[0.22em] text-powder-petal-300">
          Visión
        </p>
        <h2
          class="mt-3 font-display text-2xl sm:text-3xl font-semibold text-bone-50"
        >
          A dónde queremos llegar.
        </h2>
        <p class="mt-5 leading-relaxed text-bone-200/85">
          {vision}
        </p>
      </article>
    </div>
  </section>

  {/* VALORES */}
  <section class="bg-bone-50 py-20 sm:py-28">
    <div class="mx-auto max-w-6xl px-5 sm:px-8">
      <SectionTitle
        eyebrow="Valores"
        title="Principios innegociables. El ADN de las guerreras."
        intro="No son adornos: son los criterios que usamos para tomar cada decisión por tu marca."
      />
      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          valores.map((v, i) => (
            <ValueCard
              title={v.title}
              subtitle={v.subtitle}
              body={v.body}
              icon={icons[i]}
            />
          ))
        }
      </div>
    </div>
  </section>

  {/* SINCERIDAD */}
  <section class="bg-vintage-grape-900 py-20 sm:py-28 text-bone-50">
    <div class="mx-auto max-w-4xl px-5 sm:px-8 text-center">
      <p
        class="reveal text-xs uppercase tracking-[0.22em] text-powder-petal-300"
      >
        {sinceridad.title}
      </p>
      <blockquote
        class="reveal mt-5 font-display text-2xl sm:text-3xl md:text-4xl leading-snug"
      >
        {sinceridad.body}
      </blockquote>
      <div class="reveal mt-10">
        <Button href="/contacto" variant="secondary">
          Empezar con la consultoría gratuita
        </Button>
      </div>
    </div>
  </section>

  {/* GLOSARIO */}
  <section class="bg-bone-50 py-20 sm:py-24">
    <div class="mx-auto max-w-4xl px-5 sm:px-8">
      <SectionTitle
        eyebrow="Glosario"
        title="Tres palabras que vas a escucharnos repetir."
      />
      <dl class="mt-10 divide-y divide-space-indigo-900/10">
        {
          glosario.map((g) => (
            <div class="reveal grid gap-3 py-6 sm:grid-cols-[140px_1fr] sm:gap-8">
              <dt class="font-display text-2xl text-space-indigo-900">
                {g.term}
              </dt>
              <dd class="text-base leading-relaxed text-space-indigo-800/80">
                {g.def}
              </dd>
            </div>
          ))
        }
      </dl>
    </div>
  </section>
</Layout>
