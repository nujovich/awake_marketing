---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import SectionTitle from "../components/SectionTitle.astro";
import CoreMethod from "../components/CoreMethod.astro";
import ServiceRow from "../components/ServiceRow.astro";
import { pillarsSection, sinceridad, serviceList } from "../data/content";

const coreRows = [
  {
    letter: "C",
    name: "Claridad",
    stage: "Diagnóstico",
    body: "Auditoría técnica del ecosistema digital. Análisis DAFO y posicionamiento competitivo. Identificamos las fricciones que detienen el crecimiento.",
  },
  {
    letter: "O",
    name: "Orden",
    stage: "Estructura",
    body: "Matriz de acción que convierte el diagnóstico en hoja de ruta. Definimos criterios de ejecución y rumbo estratégico de la marca.",
  },
  {
    letter: "R",
    name: "Realce",
    stage: "Proyección",
    body: "Narrativa y sistema visual coherentes. Branding, tipografía y dirección de arte que validan tu capacidad y generan confianza inmediata.",
  },
  {
    letter: "E",
    name: "Expansión",
    stage: "Ejecución",
    body: "Gestión de canales y comunicación de alto impacto. La marca crece de forma constante, medible y estratégica.",
  },
];

const yesItems = [
  "Tu perfil está perdiendo clientes cada día.",
  "Te digo exactamente qué falla. Gratis.",
  "Resultados visibles en 60 días o no seguimos.",
  "Nos tomamos tu proyecto como algo personal.",
  "Sin permanencia. Mes a mes.",
];
const noItems = [
  "Somos la mejor agencia de España.",
  "Ofrecemos soluciones integrales 360°.",
  "Garantizamos el éxito de tu marca.",
  "Contamos con amplia experiencia.",
  "Planes flexibles adaptados a ti.",
];

const marqueeWords = [
  "Claridad",
  "Orden",
  "Realce",
  "Expansión",
  "Autoridad",
  "Resultados",
  "Honestidad",
  "Estructura",
];
---

<Layout>
  {/* ========= HERO ========= */}
  <section class="relative bg-violet overflow-hidden">
    <div
      class="mx-auto max-w-[1280px] px-6 sm:px-14 pt-20 sm:pt-28 pb-24 sm:pb-32"
    >
      <div class="grid gap-12 lg:grid-cols-12 lg:gap-16 items-end">
        <div class="lg:col-span-8">
          <div class="reveal flex items-center gap-4">
            <span class="h-px flex-1 bg-paper/20"></span>
            <span
              class="font-display text-[11px] font-semibold uppercase tracking-[0.22em] text-paper/50"
            >
              Valencia · Alicante
            </span>
          </div>

          <h1
            class="reveal mt-12 font-display text-5xl sm:text-6xl md:text-7xl lg:text-[84px] font-extrabold leading-[0.95] tracking-[-0.03em] text-paper"
          >
            Potenciamos <br />
            tu
            <span class="relative inline-block">
              marca
              <span class="absolute left-0 -bottom-1 h-1 w-full bg-coral"
              ></span>
            </span>.
          </h1>

          <p
            class="reveal mt-10 max-w-xl text-base sm:text-lg font-light leading-relaxed text-paper/80"
          >
            Transformamos negocios invisibles en marcas creativas y estrategias
            cuidadas.
            <span class="font-semibold text-paper"
              >Cremos conexiones reales</span
            >
            <span class="italic">entre la empresa y tu comunidad.</span>
          </p>

          <div class="reveal mt-12 flex flex-wrap items-center gap-6">
            <Button href="/contacto" variant="outline" onDark={true}>
              Diagnóstico gratis
            </Button>
            <Button href="#metodo" variant="ghost" onDark={true}
              >Conoce nuestro método</Button
            >
          </div>
        </div>
      </div>
    </div>

    {/* Marquee */}
    <div class="border-t border-paper/10 overflow-hidden bg-violet-deep py-6">
      <div
        class="marquee-track flex whitespace-nowrap font-display text-2xl sm:text-3xl font-extrabold uppercase tracking-[-0.01em] text-paper/90"
      >
        {
          [...marqueeWords, ...marqueeWords].map((w, i) => (
            <span class="px-8 flex items-center gap-8">
              {w}
              <span class={i % 3 === 1 ? "text-paper/40" : "text-coral"}>
                ●
              </span>
            </span>
          ))
        }
      </div>
    </div>
  </section>

  {/* ========= INTRO / MANIFIESTO ========= */}
  <section class="bg-paper border-b border-rule">
    <div class="mx-auto max-w-[1280px] px-6 sm:px-14 py-24 sm:py-32">
      <div class="grid gap-12 lg:grid-cols-12">
        <div class="lg:col-span-4">
          <SectionTitle
            number="01"
            eyebrow="Manifiesto"
            title="No vendemos humo. Vendemos estructura."
          />
        </div>
        <div class="lg:col-span-7 lg:col-start-6">
          <p
            class="reveal font-display text-2xl sm:text-3xl font-light leading-[1.25] tracking-[-0.01em] text-ink"
          >
            Hay marcas con potencial enorme atrapadas en una operación
            desordenada. <span class="italic text-violet font-light"
              >Las despertamos</span
            >. Diagnosticamos lo que frena el crecimiento, ordenamos la
            ejecución y construimos una presencia visual que transmite autoridad
            desde el primer segundo.
          </p>
          <div
            class="reveal mt-12 grid grid-cols-3 gap-8 border-t border-rule pt-8"
          >
            <div>
              <p
                class="font-display text-[11px] font-semibold uppercase tracking-[0.22em] text-graphite/60"
              >
                Método
              </p>
              <p class="mt-2 font-display text-3xl font-extrabold text-ink">
                CORE
              </p>
            </div>
            <div>
              <p
                class="font-display text-[11px] font-semibold uppercase tracking-[0.22em] text-graphite/60"
              >
                Fases
              </p>
              <p class="mt-2 font-display text-3xl font-extrabold text-ink">
                04
              </p>
            </div>
            <div>
              <p
                class="font-display text-[11px] font-semibold uppercase tracking-[0.22em] text-graphite/60"
              >
                Permanencia
              </p>
              <p class="mt-2 font-display text-3xl font-extrabold text-violet">
                Cero
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* ========= MÉTODO CORE ========= */}
  <section id="metodo" class="bg-offwhite">
    <div class="mx-auto max-w-[1280px] px-6 sm:px-14 py-24 sm:py-32">
      <div class="grid gap-12 lg:grid-cols-12">
        <div class="lg:col-span-5">
          <SectionTitle
            number="02"
            eyebrow="Método CORE"
            title="Cuatro fases. Cero relleno."
            intro="Del diagnóstico al impacto medible. Cada fase tiene entregables claros y criterios de avance."
          />
        </div>
      </div>

      <div class="reveal mt-16">
        <CoreMethod variant="compact" />
      </div>

      <div class="reveal mt-16">
        <Button href="/servicios#core" variant="secondary">
          Ver método completo
        </Button>
      </div>
    </div>
  </section>

  {/* ========= PILARES / VALORES ========= */}
  <section class="bg-violet-soft border-b border-rule">
    <div class="mx-auto max-w-[1280px] px-6 sm:px-14 py-24 sm:py-32">
      <div class="grid gap-12 lg:grid-cols-12 mb-16">
        <div class="lg:col-span-6">
          <SectionTitle
            number="03"
            eyebrow={pillarsSection.eyebrow}
            title={pillarsSection.title}
            intro={pillarsSection.intro}
          />
        </div>
      </div>

      <div
        class="grid gap-px bg-violet-line border border-violet-line sm:grid-cols-2 lg:grid-cols-4"
      >
        {
          pillarsSection.pillars.map((pillar, i) => (
            <article
              class="reveal group bg-paper p-8 sm:p-10 transition-colors duration-300 hover:bg-ink hover:text-paper"
              style={`transition-delay: ${i * 60}ms`}
            >
              <div class="flex items-center justify-between">
                <span class="font-display text-[11px] font-semibold uppercase tracking-[0.22em] text-violet group-hover:text-coral">
                  0{i + 1}
                </span>
                <span class="h-1.5 w-1.5 bg-violet group-hover:bg-coral" />
              </div>
              <h3 class="mt-10 font-display text-2xl font-bold tracking-[-0.01em]">
                {pillar.title}
              </h3>
              <p class="mt-4 text-sm font-light leading-relaxed text-graphite/85 group-hover:text-paper/80">
                {pillar.body}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  {/* ========= SERVICIOS ========= */}
  <section class="bg-violet text-paper">
    <div class="mx-auto max-w-[1280px] px-6 sm:px-14 py-24 sm:py-32">
      <div class="grid gap-12 lg:grid-cols-12 mb-16">
        <div class="lg:col-span-7">
          <SectionTitle
            number="04"
            eyebrow="Servicios"
            title="Lo que hacemos por tu marca."
            intro="Cuatro líneas de trabajo. Una sola obsesión: que tu negocio vuelva a aparecer donde importa."
            tone="dark"
          />
        </div>
      </div>

      <div>
        {
          serviceList.map((svc) => (
            <ServiceRow
              idx={svc.idx}
              name={svc.name}
              nameItalic={svc.nameItalic}
              desc={svc.desc}
              href={svc.href}
            />
          ))
        }
      </div>

      <div class="reveal mt-16">
        <Button href="/servicios" variant="outline" onDark={true}
          >Ver todos los servicios</Button
        >
      </div>
    </div>
  </section>

  {/* ========= SÍ / NO DECIMOS ========= */}
  <section class="bg-offwhite border-b border-rule">
    <div class="mx-auto max-w-[1280px] px-6 sm:px-14 py-24 sm:py-32">
      <div class="grid gap-12 lg:grid-cols-12 mb-16">
        <div class="lg:col-span-6">
          <SectionTitle
            number="05"
            eyebrow="Voz & tono"
            title="Cercana pero seria. Directa. Sin artificios."
            intro="Hablamos de tú a tú. Lo que decimos lo cumplimos. Lo que no podemos cumplir, no lo prometemos."
          />
        </div>
      </div>

      <div class="grid gap-px bg-rule border border-rule lg:grid-cols-2">
        <div class="bg-paper p-10 sm:p-12">
          <p
            class="font-display text-[11px] font-semibold uppercase tracking-[0.22em] text-violet"
          >
            ✓ Sí decimos
          </p>
          <ul class="mt-8 space-y-5">
            {
              yesItems.map((t) => (
                <li class="reveal flex items-start gap-4 border-b border-rule pb-5 last:border-b-0">
                  <span class="mt-2 h-1.5 w-1.5 flex-none bg-coral" />
                  <p class="font-display text-lg sm:text-xl font-semibold leading-snug tracking-[-0.01em] text-ink">
                    "{t}"
                  </p>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="bg-ink text-paper p-10 sm:p-12">
          <p
            class="font-display text-[11px] font-semibold uppercase tracking-[0.22em] text-coral"
          >
            ✗ No decimos
          </p>
          <ul class="mt-8 space-y-5">
            {
              noItems.map((t) => (
                <li class="reveal flex items-start gap-4 border-b border-paper/15 pb-5 last:border-b-0">
                  <span class="mt-2 h-px w-4 flex-none bg-paper/40" />
                  <p class="text-lg sm:text-xl font-light italic leading-snug text-paper/60 line-through decoration-paper/20">
                    {t}
                  </p>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>

  {/* ========= CIERRE ========= */}
  <section class="bg-violet-deep text-paper">
    <div class="mx-auto max-w-[1280px] px-6 sm:px-14 py-28 sm:py-40">
      <div class="grid gap-12 lg:grid-cols-12 items-end">
        <div class="lg:col-span-8">
          <p
            class="reveal font-display text-[11px] font-semibold uppercase tracking-[0.32em] text-paper/60"
          >
            — Sinceridad ante todo
          </p>
          <blockquote
            class="reveal mt-10 font-display text-3xl sm:text-5xl md:text-6xl font-extrabold leading-[1.02] tracking-[-0.02em]"
          >
            "{sinceridad.body}"
          </blockquote>
        </div>
        <div class="lg:col-span-4">
          <div class="reveal border-t border-paper/20 pt-8">
            <p
              class="font-display text-[11px] font-semibold uppercase tracking-[0.22em] text-paper/50"
            >
              ¿Hablamos?
            </p>
            <p class="mt-6 text-base font-light leading-relaxed text-paper/70">
              Reservá un diagnóstico gratuito. Te decimos exactamente qué falla
              en tu ecosistema digital, y si podemos ayudarte. Sin compromiso.
            </p>
            <div class="mt-10">
              <Button href="/contacto" variant="outline" onDark={true}>
                Reservar diagnóstico
              </Button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
