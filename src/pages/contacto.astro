---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import SectionTitle from "../components/SectionTitle.astro";
import { brand, faq } from "../data/content";
---

<Layout
  title={`Contacto — ${brand.full}`}
  description="Reservá tu consultoría de descubrimiento gratuita: 30 minutos por videollamada para entender qué necesita tu marca."
>
  {/* HERO */}
  <section class="relative overflow-hidden bg-bone-50 py-16 sm:py-24">
    <div
      class="absolute inset-0 -z-10 opacity-50"
      style="background: radial-gradient(50% 50% at 80% 30%, rgba(108,91,164,0.18), transparent 60%);"
    >
    </div>

    <div class="mx-auto max-w-6xl px-5 sm:px-8 grid gap-12 lg:grid-cols-12">
      <div class="lg:col-span-6">
        <p
          class="reveal text-xs font-medium uppercase tracking-[0.22em] text-powder-petal-600"
        >
          Consultoría de Descubrimiento — Gratis
        </p>
        <h1
          class="reveal mt-5 font-display text-4xl sm:text-5xl md:text-6xl font-semibold leading-[1.05] tracking-tight text-space-indigo-900"
        >
          30 minutos para
          <span class="italic text-vintage-grape-700">conocernos</span>
          y entender qué necesita tu marca.
        </h1>
        <p
          class="reveal mt-5 max-w-xl text-base sm:text-lg leading-relaxed text-space-indigo-800/80"
        >
          Si tu marca está bien, te lo decimos. Si no podemos ayudarte, también.
          Sin letra chica.
        </p>

        <ul class="reveal mt-8 space-y-3 text-sm text-space-indigo-800/80">
          <li class="flex items-start gap-3">
            <span class="mt-1 h-2 w-2 rounded-full bg-jungle-teal-600 flex-none"></span>
            <span>Videollamada de 30 min, sin compromiso.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-1 h-2 w-2 rounded-full bg-jungle-teal-600 flex-none"></span>
            <span>Diagnóstico inicial y recomendación honesta de próximos pasos.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="mt-1 h-2 w-2 rounded-full bg-jungle-teal-600 flex-none"></span>
            <span>Si encajamos, presupuestamos en el momento.</span>
          </li>
        </ul>

        <div class="reveal mt-10 grid gap-4 sm:grid-cols-2 max-w-md">
          <a
            href={`mailto:${brand.email}`}
            class="rounded-2xl bg-bone-100 p-4 ring-1 ring-space-indigo-900/5 transition-all hover:-translate-y-0.5 hover:ring-space-indigo-700/30"
          >
            <p class="text-xs uppercase tracking-[0.18em] text-space-indigo-800/60">
              Email
            </p>
            <p class="mt-1 font-medium text-space-indigo-900 text-sm">
              {brand.email}
            </p>
          </a>
          <div
            class="rounded-2xl bg-bone-100 p-4 ring-1 ring-space-indigo-900/5"
          >
            <p class="text-xs uppercase tracking-[0.18em] text-space-indigo-800/60">
              WhatsApp
            </p>
            <p class="mt-1 font-medium text-space-indigo-900 text-sm">
              {brand.whatsapp}
            </p>
          </div>
        </div>
      </div>

      {/* FORM */}
      <div class="lg:col-span-6">
        <form
          class="reveal rounded-3xl bg-space-indigo-950 p-8 sm:p-10 text-bone-100 shadow-xl shadow-space-indigo-900/15"
          action={`mailto:${brand.email}`}
          method="post"
          enctype="text/plain"
        >
          <p
            class="text-xs font-medium uppercase tracking-[0.22em] text-powder-petal-300"
          >
            Reservar consultoría
          </p>
          <h2 class="mt-3 font-display text-2xl sm:text-3xl font-semibold text-bone-50">
            Contanos de tu marca.
          </h2>

          <div class="mt-6 space-y-4">
            <label class="block">
              <span class="text-xs uppercase tracking-[0.18em] text-bone-200/60">
                Nombre
              </span>
              <input
                required
                name="nombre"
                type="text"
                placeholder="Tu nombre"
                class="mt-2 w-full rounded-xl bg-space-indigo-900/60 border border-bone-100/10 px-4 py-3 text-sm text-bone-50 placeholder:text-bone-200/40 focus:outline-none focus:border-powder-petal-300 focus:ring-2 focus:ring-powder-petal-300/30 transition-colors"
              />
            </label>

            <label class="block">
              <span class="text-xs uppercase tracking-[0.18em] text-bone-200/60">
                Email
              </span>
              <input
                required
                name="email"
                type="email"
                placeholder="hola@tumarca.com"
                class="mt-2 w-full rounded-xl bg-space-indigo-900/60 border border-bone-100/10 px-4 py-3 text-sm text-bone-50 placeholder:text-bone-200/40 focus:outline-none focus:border-powder-petal-300 focus:ring-2 focus:ring-powder-petal-300/30 transition-colors"
              />
            </label>

            <label class="block">
              <span class="text-xs uppercase tracking-[0.18em] text-bone-200/60">
                Marca o negocio
              </span>
              <input
                name="marca"
                type="text"
                placeholder="Cómo se llama"
                class="mt-2 w-full rounded-xl bg-space-indigo-900/60 border border-bone-100/10 px-4 py-3 text-sm text-bone-50 placeholder:text-bone-200/40 focus:outline-none focus:border-powder-petal-300 focus:ring-2 focus:ring-powder-petal-300/30 transition-colors"
              />
            </label>

            <label class="block">
              <span class="text-xs uppercase tracking-[0.18em] text-bone-200/60">
                ¿En qué te podemos ayudar?
              </span>
              <select
                name="servicio"
                class="mt-2 w-full rounded-xl bg-space-indigo-900/60 border border-bone-100/10 px-4 py-3 text-sm text-bone-50 focus:outline-none focus:border-powder-petal-300 focus:ring-2 focus:ring-powder-petal-300/30 transition-colors"
              >
                <option>Consultoría gratuita</option>
                <option>Diagnóstico RADAR</option>
                <option>Branding</option>
                <option>Gestión de redes sociales</option>
                <option>Pack a medida</option>
              </select>
            </label>

            <label class="block">
              <span class="text-xs uppercase tracking-[0.18em] text-bone-200/60">
                Contanos un poco más
              </span>
              <textarea
                name="mensaje"
                rows="4"
                placeholder="¿Qué te frena hoy? ¿Qué necesitás?"
                class="mt-2 w-full rounded-xl bg-space-indigo-900/60 border border-bone-100/10 px-4 py-3 text-sm text-bone-50 placeholder:text-bone-200/40 focus:outline-none focus:border-powder-petal-300 focus:ring-2 focus:ring-powder-petal-300/30 transition-colors resize-none"
              ></textarea>
            </label>
          </div>

          <button
            type="submit"
            class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-full bg-powder-petal-500 px-5 py-3 text-sm font-medium text-bone-50 transition-all duration-200 hover:bg-powder-petal-400 hover:-translate-y-0.5"
          >
            Enviar mensaje
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </button>
          <p class="mt-3 text-[11px] text-bone-200/50 text-center">
            Te responderemos en menos de 24 h hábiles.
          </p>
        </form>
      </div>
    </div>
  </section>

  {/* FAQ */}
  <section class="bg-bone-100 py-20 sm:py-24">
    <div class="mx-auto max-w-4xl px-5 sm:px-8">
      <SectionTitle
        eyebrow="Preguntas frecuentes"
        title="Lo que nos preguntan antes de empezar."
      />
      <div class="mt-10 space-y-3">
        {
          faq.map((item) => (
            <details class="reveal group rounded-2xl bg-bone-50 p-5 ring-1 ring-space-indigo-900/5 open:ring-space-indigo-700/30 transition-all">
              <summary class="flex cursor-pointer list-none items-center justify-between gap-4 font-display text-lg text-space-indigo-900">
                {item.q}
                <svg
                  class="h-5 w-5 flex-none text-space-indigo-700 transition-transform duration-200 group-open:rotate-45"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <path d="M12 5v14" />
                  <path d="M5 12h14" />
                </svg>
              </summary>
              <p class="mt-3 text-sm leading-relaxed text-space-indigo-800/80">
                {item.a}
              </p>
            </details>
          ))
        }
      </div>
    </div>
  </section>
</Layout>
