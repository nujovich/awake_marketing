---
import Layout from "../../layouts/Layout.astro";
import Button from "../../components/Button.astro";
import SectionTitle from "../../components/SectionTitle.astro";
import PriceCard from "../../components/PriceCard.astro";
import CoreMethod from "../../components/CoreMethod.astro";
import t from "../../i18n/es.json";
import { getLocalizedUrl } from "../../i18n/utils";

const locale = "es";
const currentSlug = "servicios";
const contactHref = getLocalizedUrl(locale, "contacto");
---

<Layout
    locale={locale}
    currentSlug={currentSlug}
    title={t.services.metaTitle}
    description={t.services.metaDescription}
>
    {/* HERO */}
    <section class="relative overflow-hidden bg-offwhite py-16 sm:py-24">
        <div class="mx-auto max-w-4xl px-5 sm:px-8 text-center">
            <p
                class="reveal text-xs font-medium uppercase tracking-[0.22em] text-violet"
            >
                {t.services.heroEyebrow}
            </p>
            <h1
                class="reveal mt-5 font-display text-4xl sm:text-5xl md:text-6xl font-semibold leading-[1.05] tracking-tight text-ink"
            >
                {t.services.heroTitle}
            </h1>
            <p
                class="reveal mt-5 text-base sm:text-lg leading-relaxed text-graphite/80"
            >
                {t.services.heroBody}
            </p>
            <div class="reveal mt-8 flex flex-wrap justify-center gap-3">
                <Button href="#diagnostico" variant="ghost"
                    >{t.services.navDiagnostico}</Button
                >
                <Button href="#branding" variant="ghost"
                    >{t.services.navBranding}</Button
                >
                <Button href="#web" variant="ghost">{t.services.navWeb}</Button>
                <Button href="#rrss" variant="ghost"
                    >{t.services.navRrss}</Button
                >
                <Button href="#core" variant="ghost"
                    >{t.services.navCore}</Button
                >
            </div>
        </div>
    </section>

    {/* MÉTODO CORE */}
    <section id="core" class="bg-violet-deep py-20 sm:py-28 text-paper">
        <div class="mx-auto max-w-6xl px-5 sm:px-8">
            <SectionTitle
                eyebrow={t.services.coreEyebrow}
                title={t.services.coreTitle}
                intro={t.services.coreIntro}
                tone="dark"
            />
            <div class="mt-12">
                <CoreMethod steps={t.services.coreMethodFull} tone="dark" />
            </div>
        </div>
    </section>

    {/* DIAGNÓSTICO */}
    <section id="diagnostico" class="bg-paper py-20 sm:py-28 scroll-mt-20">
        <div class="mx-auto max-w-6xl px-5 sm:px-8">
            <SectionTitle
                eyebrow={t.services.diagnosticoEyebrow}
                title={t.services.diagnosticoTitle}
                intro={t.services.diagnosticoIntro}
            />
            <div class="mt-12 grid gap-6 md:grid-cols-2">
                {
                    t.services.diagnosticoTiers.map((tier) => (
                        <PriceCard
                            tier={tier}
                            timeLabel={t.services.timeLabel}
                        />
                    ))
                }
            </div>
        </div>
    </section>

    {/* BRANDING */}
    <section id="branding" class="bg-offwhite py-20 sm:py-28 scroll-mt-20">
        <div class="mx-auto max-w-6xl px-5 sm:px-8">
            <SectionTitle
                eyebrow={t.services.brandingEyebrow}
                title={t.services.brandingTitle}
                intro={t.services.brandingIntro}
            />
            <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
                {
                    t.services.brandingTiers.map((tier) => (
                        <PriceCard
                            tier={tier}
                            timeLabel={t.services.timeLabel}
                        />
                    ))
                }
            </div>
            <p class="reveal mt-8 text-sm text-graphite/65 max-w-2xl">
                {t.services.brandingNote}
            </p>
        </div>
    </section>

    {/* WEB */}
    <section id="web" class="bg-offwhite py-20 sm:py-28 scroll-mt-20">
        <div class="mx-auto max-w-6xl px-5 sm:px-8">
            <SectionTitle
                eyebrow={t.services.webEyebrow}
                title={t.services.webTitle}
                intro={t.services.webIntro}
            />
            <div class="mt-12 grid gap-6 md:grid-cols-3">
                {
                    t.services.webTiers.map((tier) => (
                        <PriceCard
                            tier={tier}
                            timeLabel={t.services.timeLabel}
                        />
                    ))
                }
            </div>
        </div>
    </section>

    {/* RRSS */}
    <section id="rrss" class="bg-paper py-20 sm:py-28 scroll-mt-20">
        <div class="mx-auto max-w-6xl px-5 sm:px-8">
            <SectionTitle
                eyebrow={t.services.rrssEyebrow}
                title={t.services.rrssTitle}
                intro={t.services.rrssIntro}
            />
            <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
                {
                    t.services.rrsssTiers.map((tier) => (
                        <PriceCard
                            tier={tier}
                            timeLabel={t.services.timeLabel}
                        />
                    ))
                }
            </div>
        </div>
    </section>

    {/* CONDICIONES DE PAGO */}
    <section class="bg-violet py-20 sm:py-28 text-paper">
        <div class="mx-auto max-w-6xl px-5 sm:px-8">
            <SectionTitle
                eyebrow={t.services.pagosEyebrow}
                title={t.services.condicionesPago.title}
                intro={t.services.pagosIntro}
                tone="dark"
            />
            <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
                {
                    t.services.condicionesPago.items.map((item, i) => (
                        <article
                            class="reveal rounded-2xl bg-violet-deep/50 p-6 ring-1 ring-paper/10 transition-colors hover:bg-violet-deep"
                            style={`transition-delay: ${i * 60}ms`}
                        >
                            <h3 class="font-display text-xl font-semibold text-paper">
                                {item.title}
                            </h3>
                            <p class="mt-3 text-sm leading-relaxed text-paper/75">
                                {item.body}
                            </p>
                        </article>
                    ))
                }
            </div>
        </div>
    </section>

    {/* CTA */}
    <section class="bg-paper py-20 sm:py-24">
        <div class="mx-auto max-w-3xl px-5 sm:px-8 text-center">
            <h2
                class="reveal font-display text-3xl sm:text-4xl font-semibold text-ink"
            >
                {t.services.ctaTitle}
            </h2>
            <p class="reveal mt-4 text-base sm:text-lg text-graphite/75">
                {t.services.ctaBody}
            </p>
            <div class="reveal mt-8">
                <Button href={contactHref} variant="primary">
                    {t.services.ctaLabel}
                </Button>
            </div>
        </div>
    </section>
</Layout>
