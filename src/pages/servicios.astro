---
import Layout from "../layouts/Layout.astro";
import Button from "../components/Button.astro";
import SectionTitle from "../components/SectionTitle.astro";
import PriceCard from "../components/PriceCard.astro";
import CoreMethod from "../components/CoreMethod.astro";
import { brand, condicionesPago } from "../data/content";
import { branding, rrss, diagnostico } from "../data/services";
---

<Layout
  title={`Servicios — ${brand.full}`}
  description="Diagnóstico, branding y gestión de redes. El Método CORE aplicado a paquetes claros y precios honestos."
>
  {/* HERO */}
  <section class="relative overflow-hidden bg-bone-50 py-16 sm:py-24">
    <div
      class="absolute inset-0 -z-10 opacity-50"
      style="background: radial-gradient(50% 50% at 30% 30%, rgba(189,119,66,0.18), transparent 60%);"
    >
    </div>
    <div class="mx-auto max-w-4xl px-5 sm:px-8 text-center">
      <p class="reveal text-xs font-medium uppercase tracking-[0.22em] text-powder-petal-600">
        Servicios
      </p>
      <h1
        class="reveal mt-5 font-display text-4xl sm:text-5xl md:text-6xl font-semibold leading-[1.05] tracking-tight text-space-indigo-900"
      >
        Paquetes claros. Sin letra chica.
      </h1>
      <p
        class="reveal mt-5 text-base sm:text-lg leading-relaxed text-space-indigo-800/80"
      >
        Tres familias de servicios, una sola lógica: el Método CORE. Empezás
        donde estés y avanzás al ritmo del negocio.
      </p>
      <div class="reveal mt-8 flex flex-wrap justify-center gap-3">
        <Button href="#diagnostico" variant="ghost">Diagnóstico</Button>
        <Button href="#branding" variant="ghost">Branding</Button>
        <Button href="#rrss" variant="ghost">Redes Sociales</Button>
        <Button href="#core" variant="ghost">Método CORE</Button>
      </div>
    </div>
  </section>

  {/* MÉTODO CORE */}
  <section id="core" class="bg-space-indigo-950 py-20 sm:py-28 text-bone-50">
    <div class="mx-auto max-w-6xl px-5 sm:px-8">
      <SectionTitle
        eyebrow="Método CORE"
        title="El sistema de transformación que aplicamos a cada cliente."
        intro="Cuatro etapas que van directo al núcleo. Cada paquete usa este método según el momento de tu marca."
        tone="dark"
      />
      <div class="mt-12">
        <CoreMethod variant="full" tone="dark" />
      </div>
    </div>
  </section>

  {/* DIAGNÓSTICO */}
  <section id="diagnostico" class="bg-bone-50 py-20 sm:py-28 scroll-mt-20">
    <div class="mx-auto max-w-6xl px-5 sm:px-8">
      <SectionTitle
        eyebrow="01 · Punto de partida"
        title="Diagnóstico e impulso."
        intro="Antes de gastar un euro en diseño o redes, hay que entender qué está frenando a tu marca. Empezamos siempre por acá."
      />
      <div class="mt-12 grid gap-6 md:grid-cols-2">
        {diagnostico.map((tier) => <PriceCard tier={tier} />)}
      </div>
    </div>
  </section>

  {/* BRANDING */}
  <section id="branding" class="bg-bone-100 py-20 sm:py-28 scroll-mt-20">
    <div class="mx-auto max-w-6xl px-5 sm:px-8">
      <SectionTitle
        eyebrow="02 · Identidad"
        title="Paquetes de branding."
        intro="Identidad, imagen, construcción, tono y ADN de marca. Tres niveles, un solo objetivo: que se vea como lo que es."
      />
      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {branding.map((tier) => <PriceCard tier={tier} />)}
      </div>
      <p
        class="reveal mt-8 text-sm text-space-indigo-800/65 max-w-2xl"
      >
        Nota: en una agencia senior de Alicante / Valencia, el Pack CORE +
        Branding Total costaría unos 2.500 €. El precio de 990 € es promocional
        para 2026.
      </p>
    </div>
  </section>

  {/* RRSS */}
  <section id="rrss" class="bg-bone-50 py-20 sm:py-28 scroll-mt-20">
    <div class="mx-auto max-w-6xl px-5 sm:px-8">
      <SectionTitle
        eyebrow="03 · Awake Momentum"
        title="Gestión mensual de redes sociales."
        intro="Cinco paquetes pensados para el ciclo de vida de tu marca. El PRO es nuestra recomendación: el equilibrio justo entre diseño y crecimiento."
      />
      <div class="mt-12 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {rrss.map((tier) => <PriceCard tier={tier} />)}
      </div>
    </div>
  </section>

  {/* CONDICIONES DE PAGO */}
  <section class="bg-vintage-grape-900 py-20 sm:py-28 text-bone-50">
    <div class="mx-auto max-w-6xl px-5 sm:px-8">
      <SectionTitle
        eyebrow="Política de Guerreras"
        title={condicionesPago.title}
        intro="Todo claro desde el primer minuto. Para que Awake sea un negocio sano y vos sepas dónde te metés."
        tone="dark"
      />
      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {
          condicionesPago.items.map((item, i) => (
            <article
              class="reveal rounded-2xl bg-vintage-grape-800/60 p-6 ring-1 ring-bone-100/10 transition-colors hover:bg-vintage-grape-800"
              style={`transition-delay: ${i * 60}ms`}
            >
              <h3 class="font-display text-xl font-semibold text-bone-50">
                {item.title}
              </h3>
              <p class="mt-3 text-sm leading-relaxed text-bone-200/80">
                {item.body}
              </p>
            </article>
          ))
        }
      </div>
    </div>
  </section>

  {/* CTA */}
  <section class="bg-bone-50 py-20 sm:py-24">
    <div class="mx-auto max-w-3xl px-5 sm:px-8 text-center">
      <h2
        class="reveal font-display text-3xl sm:text-4xl font-semibold text-space-indigo-900"
      >
        ¿Cuál encaja con tu marca?
      </h2>
      <p
        class="reveal mt-4 text-base sm:text-lg text-space-indigo-800/75"
      >
        Si no estás segura, lo vemos juntas en la consultoría gratuita. 30
        minutos, sin compromiso, con recomendación honesta.
      </p>
      <div class="reveal mt-8">
        <Button href="/contacto" variant="primary">
          Reservar consultoría gratis
        </Button>
      </div>
    </div>
  </section>
</Layout>
