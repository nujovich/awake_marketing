---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { ClientRouter } from "astro:transitions";
import SpeedInsights from "@vercel/speed-insights/astro";
import Analytics from "@vercel/analytics/astro";
import { getLocalizedUrl } from "../i18n/utils";
import es from "../i18n/es.json";
import en from "../i18n/en.json";
import it from "../i18n/it.json";

const allTranslations = { es, en, it } as const;

interface Props {
  title?: string;
  description?: string;
  locale?: string;
  currentSlug?: string;
}

const {
  locale = Astro.currentLocale ?? "es",
  currentSlug = "",
  title,
  description,
} = Astro.props;

const t = allTranslations[locale as keyof typeof allTranslations] ?? es;
const resolvedTitle = title ?? `${t.brand.full} — ${t.brand.shortTagline}`;
const resolvedDescription = description ?? t.brand.tagline;
const locales = ["es", "en", "it"] as const;
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";

const canonicalUrl = `${siteUrl}${Astro.url.pathname}`;
const ogImageUrl = `${siteUrl}/og-image.png`;
const ogLocaleMap: Record<string, string> = {
  es: "es_ES",
  en: "en_GB",
  it: "it_IT",
};
const ogLocale = ogLocaleMap[locale] ?? "es_ES";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "MarketingAgency",
  name: t.brand.full,
  url: siteUrl,
  logo: `${siteUrl}/assets/logo-awake-primary.svg`,
  email: t.brand.email,
  telephone: "+34682522328",
  address: {
    "@type": "PostalAddress",
    addressLocality: "Alicante / Valencia",
    addressCountry: "ES",
  },
  description: t.brand.tagline,
  inLanguage: locale,
};
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={resolvedDescription} />
    <meta name="robots" content="index, follow" />
    <meta name="generator" content={Astro.generator} />

    <link rel="canonical" href={canonicalUrl} />
    <link
      rel="icon"
      type="image/svg+xml"
      href="/assets/logo-awake-monogram.svg"
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&family=Raleway:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&display=swap"
    />

    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content={t.brand.full} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    {
      locales.map((loc) => (
        <link
          rel="alternate"
          hreflang={loc}
          href={`${siteUrl}${getLocalizedUrl(loc, currentSlug)}`}
        />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={`${siteUrl}/es/`} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <title>{resolvedTitle}</title>
    <ClientRouter />
  </head>
  <body class="min-h-screen flex flex-col bg-paper text-ink">
    <Header t={t} locale={locale} currentSlug={currentSlug} />
    <main class="flex-1">
      <slot />
    </main>
    <Footer t={t} locale={locale} />
    <Analytics />
    <SpeedInsights />

    <script>
      const setupReveal = () => {
        const els = document.querySelectorAll<HTMLElement>(".reveal");
        if (!("IntersectionObserver" in window) || els.length === 0) {
          els.forEach((el) => el.classList.add("is-visible"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -40px 0px" },
        );
        els.forEach((el) => io.observe(el));
      };
      setupReveal();
      document.addEventListener("astro:page-load", setupReveal);
    </script>
  </body>
</html>
